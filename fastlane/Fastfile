default_platform(:android)

def parse_tag_option!(options)
  tag = options[:tag]
  UI.user_error!("tag is required (e.g. tag:1.2.3-123456)") if tag.to_s.strip.empty?
  parts = tag.split('-', 2)
  UI.user_error!("tag must be in the form name-code, e.g. 1.2.3-123456") if parts.length != 2
  version_name = parts[0]
  version_code = parts[1].to_i
  UI.user_error!("version_code must be numeric, got '#{parts[1]}'") if version_code <= 0
  [version_name, version_code]
end

platform :android do
  lane :upload_internal do |options|
    aab_path = options[:aab_path]
    upload_to_play_store(
      track: 'internal',
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  lane :upload_metadata do
    supply(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  lane :promote do |options|
    _version_name, version_code = parse_tag_option!(options)

    supply(
      track: 'internal',
      track_promote_to: 'production',
      track_promote_release_status: 'inProgress',
      rollout: "0.001", # 0.1%
      version_code: version_code,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
